-- Drag Logic
local dragging, dragStart, startPos = false, nil, nil

title.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or
       input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or
       input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or
       input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

-- Toggle Logic
local isEnabled = false

toggleBtn.MouseButton1Click:Connect(function()
    isEnabled = not isEnabled
    if isEnabled then
        toggleBtn.Text = "Disable"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(80, 200, 80)
        statusLabel.Text = "Status: ON"
        statusLabel.TextColor3 = Color3.fromRGB(80, 200, 80)
    else
        toggleBtn.Text = "Enable"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
        statusLabel.Text = "Status: OFF"
        statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
    end
end)

-- Notification function
local function notify(msg)
    local screenGui2 = Instance.new("ScreenGui")
    screenGui2.ResetOnSpawn = false
    screenGui2.Parent = playerGui

    local notifFrame = Instance.new("Frame")
    notifFrame.Size = UDim2.new(0, 250, 0, 40)
    notifFrame.Position = UDim2.new(0.5, -125, 0, 20)
    notifFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    notifFrame.BorderSizePixel = 0
    notifFrame.Parent = screenGui2

    local notifCorner = Instance.new("UICorner")
    notifCorner.CornerRadius = UDim.new(0, 8)
    notifCorner.Parent = notifFrame

    local notifLabel = Instance.new("TextLabel")
    notifLabel.Size = UDim2.new(1, 0, 1, 0)
    notifLabel.BackgroundTransparency = 1
    notifLabel.Text = "✅ " .. msg
    notifLabel.TextColor3 = Color3.fromRGB(80, 200, 80)
    notifLabel.TextSize = 14
    notifLabel.Font = Enum.Font.GothamBold
    notifLabel.Parent = notifFrame

    task.delay(4, function()
        for i = 1, 10 do
            notifFrame.BackgroundTransparency = i / 10
            notifLabel.TextTransparency = i / 10
            task.wait(0.1)
        end
        screenGui2:Destroy()
    end)
end

-- Send chat function (no cooldown, blank message fix)
local function sendChat(message)
    if not message or message == "" then return end

    task.wait(0.2)

    local ok1 = pcall(function()
        local TextChatService = game:GetService("TextChatService")
        local channel = TextChatService.TextChannels:WaitForChild("RBXGeneral", 3)
        channel:SendAsync(message)
    end)

    if not ok1 then
        pcall(function()
            ReplicatedStorage:WaitForChild("DefaultChatSystemChatEvents", 3)
                :WaitForChild("SayMessageRequest"):FireServer(message, "All")
        end)
    end
end

-- Detect gear client side
local function isGear(tool)
    local handle = tool:FindFirstChild("Handle")
    return handle and handle:FindFirstChildOfClass("SpecialMesh")
end

local function watchBackpack()
    local backpack = player:WaitForChild("Backpack", 10)
    if not backpack then return end

    local function checkItem(item)
        if item:IsA("Tool") and isGear(item) then
            if isEnabled then
                task.wait(0.2)
                sendChat(":ungear all")
                notify("Gear detected! Running :ungear all")
            end
        end
    end

    for _, item in ipairs(backpack:GetChildren()) do
        checkItem(item)
    end

    backpack.ChildAdded:Connect(checkItem)
end

-- Watch on spawn
player.CharacterAdded:Connect(function()
    task.wait(1)
    watchBackpack()
end)

-- Startup notification and watch immediately
notify("Anti-Gear is running!")
watchBackpack()
